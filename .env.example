# Cloudflare Workers Environment Variables Example
# Copy this file to .dev.vars for local development
# For production, set these in Cloudflare Dashboard under Workers > Settings > Variables

# KV Namespace IDs (create these with: wrangler kv:namespace create NAMESPACE_NAME)
# Example format: 1234567890abcdef1234567890abcdef
USERS_KV_ID=your_users_kv_namespace_id_here
ARTICLES_KV_ID=your_articles_kv_namespace_id_here
HISTORY_KV_ID=your_history_kv_namespace_id_here

# Security Secrets
# Generate with: openssl rand -hex 32
USER_ID_SALT=your_random_salt_for_user_id_hashing_here_use_openssl_rand_hex_32
DIGEST_LINK_SECRET=your_random_secret_for_digest_link_signing_here_use_openssl_rand_hex_32

# Optional: API Configuration
# Maximum articles to fetch per scraping session
MAX_ARTICLES_PER_SCRAPE=50

# Maximum articles to include in daily digest
MAX_DIGEST_ARTICLES=15

# Digest link expiration in hours (how long digest links remain valid)
DIGEST_EXPIRATION_HOURS=48

# Minimum reading time in seconds to count as "read" for learning
MIN_READING_TIME_SECONDS=10

# User agent for Ynet scraping (be respectful, identify your service)
USER_AGENT=PersonalMorningDigest/1.0 (Cloudflare Worker; +https://yourdomain.com)